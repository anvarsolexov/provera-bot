name: Render Botni Uyg'oq Saqlash

on:
  schedule:
    # Har 5 daqiqada avtomatik ishga tushadi
    - cron: '*/5 * * * *'
  workflow_dispatch: # Istalgan payt qo'lda ham ishga tushirish uchun

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - name: Render serverga so'rov yuborish
        run: |
          curl -s https://provera-bot.onrender.com > /dev/null
          echo "Render serverga muvaffaqiyatli ping yuborildi!"
